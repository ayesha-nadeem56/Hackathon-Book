# =============================================================================
# Book Content Embedding Pipeline — Environment Configuration
# Copy this file to .env and fill in your credentials.
# .env is gitignored and must NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — pipeline will raise ValueError if any of these are missing
# -----------------------------------------------------------------------------

# Root URL of the deployed Docusaurus site (must be publicly accessible)
BASE_URL=https://hackathon-book-uogx.vercel.app/

# Cohere API key — get from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=m431LhnMPTZM0TPjqyRlgxcbsSflGXeaqUBQT9AZ

# Qdrant Cloud cluster endpoint (format: https://<cluster-id>.qdrant.io)
QDRANT_URL=https://7c3f22d7-1cc5-4094-a432-904c95adf3bd.us-east-1-1.aws.cloud.qdrant.io:6333

# Qdrant Cloud API key — get from https://cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.8NflGpTDhY9fHT2Pk_AkatcZkPxnl8hUrWMOSxoMi5E

# -----------------------------------------------------------------------------
# OPTIONAL — sensible defaults shown; override only if needed
# -----------------------------------------------------------------------------

# Qdrant collection name (created automatically if it does not exist)
# WARNING: Free tier allows only 1 collection — use the same name across runs
COLLECTION_NAME=book-embeddings

# Cohere embedding model — do not change unless you need multilingual support
COHERE_MODEL=embed-english-v3.0

# Maximum characters per text chunk (1000 ≈ 150–200 words)
CHUNK_SIZE=1000

# Character overlap between adjacent chunks (preserves cross-boundary context)
CHUNK_OVERLAP=200

# Number of chunks sent per Cohere API call (max 2048; 96 is a safe default)
EMBED_BATCH_SIZE=96

# Minimum characters for a chunk to be retained (discard near-empty chunks)
MIN_CHUNK_CHARS=100
